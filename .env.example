# Supabase (optional). Copy this file to `.env` and fill in your project values.
# If these are absent, Origin runs in pure guest/local mode with no backend and
# no network calls — everything is stored in localStorage only.
#
# Both values are *public* client keys; the data is protected by Row Level
# Security (see supabase/migrations), not by keeping the anon key secret.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
