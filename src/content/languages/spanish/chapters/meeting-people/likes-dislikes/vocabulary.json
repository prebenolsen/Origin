  { "en": "I love it", "es": "me encanta", "category": "opinion", "note": "Stronger than \"me gusta\"." },
  { "en": "I hate", "es": "odio", "category": "opinion", "note": "Strong; for something milder say \"no me gusta\"." },
  { "en": "I prefer", "es": "prefiero", "category": "opinion" },
